# Modal Research Swarm API endpoint
MODAL_ENDPOINT_URL=

# Supabase (client-side -- used for team CRUD + realtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase (server-side -- used by Modal backend)
# Set as Modal secret: `modal secret create supabase-secret SUPABASE_URL=... SUPABASE_SERVICE_ROLE_KEY=...`

# Search API keys (Modal secret: `modal secret create search-api-keys TAVILY_API_KEY=... GITHUB_TOKEN=... WANDB_API_KEY=...`)

# Supermemory (optional – for AI memory integration: https://supermemory.ai)
# SUPERMEMORY_API_KEY=your_supermemory_api_key
